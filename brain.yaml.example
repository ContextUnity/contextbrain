# =============================================================================
# ContextBrain - brain.yaml.example
# =============================================================================
# Place in .contextunity/brain.yml (project) or /etc/contextunity/brain.yml (system).
# Values here OVERRIDE .env for non-secret settings.
# SECRETS (api keys, passwords) MUST stay in .env or systemd-creds - never here.
# See: packages/core/src/contextunity/core/config/loader.py
# =============================================================================

# -- Logging ------------------------------------------------------------------
log_level: INFO
# log_json: false

# -- gRPC Server --------------------------------------------------------------
# grpc_reuse_port: false
# grpc_host: localhost

# -- Brain-Specific -----------------------------------------------------------
# port: 50051
# instance_name: shared
# news_engine: true

# database:
#   url: postgresql+psycopg://user:pass@localhost:5432/brain  # <- move to .env!
#   schema: brain
#   pool_min_size: 2
#   pool_max_size: 10
#   rls_enabled: false
#   pgvector_dim: 768

# BrainCells use exactly one deployment-wide vector space. The default runs
# EmbeddingGemma in-process with ONNX Runtime (native 768 dimensions); no
# Ollama process is required. Local Python installs cache the pinned model on
# first use; the production Brain image bundles it and runs offline. Changing
# space_id/model requires re-embedding all affected cells before vector
# retrieval is enabled again.
# embeddings:
#   provider: onnx
#   space_id: embeddinggemma-300m-onnx-768-v1
#   model: onnx-community/embeddinggemma-300m-ONNX
#   dimension: 768
#   device: auto  # auto | cpu | cuda | coreml | dml
#   model_cache_dir: /var/cache/contextunity/huggingface
#
# External providers are opt-in. endpoint is the complete embeddings endpoint;
# Brain does not guess provider-specific URL paths. Set api_key only from an
# environment/credential source, never in this file.
# embeddings:
#   provider: openai  # openai | ollama | vllm | sentence_transformers
#   space_id: text-embedding-3-small-1536-v1
#   model: text-embedding-3-small
#   dimension: 1536
#   endpoint: https://api.openai.com/v1/embeddings

# Durable asynchronous cell embedding enrichment is opt-in.
# embedding_enrichment:
#   enabled: false
#   max_input_chars: 12000
#   max_pending_per_tenant: 10000
#   lease_seconds: 300

# models:
#   default_llm: openai/gpt-5-mini
#   rag:
#     intent:
#       model: vertex/gemini-2.5-flash-lite
#     suggestions:
#       model: vertex/gemini-2.5-flash
#     generation:
#       model: vertex/gemini-2.5-flash

# -- Observability ------------------------------------------------------------
# BrainSynapse rollout gates. Defaults are false in code; enable only after
# Phase 2 validation gates pass for the target environment.
# synapses:
#   enabled: false
#   decay_enabled: false
